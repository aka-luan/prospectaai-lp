---
---
<section id="planos" class="py-20 md:py-32 px-6">
    <div class="max-w-[1440px] mx-auto">
        <h2 class="bebas text-5xl md:text-6xl mb-10 md:mb-16">ESCOLHA SEU TERMINAL</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-0">
            <!-- Card 1 -->
            <div class="anim-pricing-card border border-white/10 p-8 md:p-10 flex flex-col hover:bg-white/5 transition-all">
                <span class="dm-mono text-secondary text-xs mb-4 uppercase tracking-widest">ENTRY_LEVEL</span>
                <h3 class="bebas text-3xl md:text-4xl mb-2">STARTER</h3>
                <div class="bebas text-5xl md:text-6xl text-primary mb-8">R$297<span class="text-xl">/mês</span></div>
                <ul class="dm-mono text-sm space-y-4 mb-12 text-secondary uppercase">
                    <li>/ 50 LEADS POR MÊS</li>
                    <li>/ SUPORTE VIA EMAIL</li>
                    <li>/ DASHBOARD BÁSICO</li>
                    <li>/ FILTROS GEOGRÁFICOS</li>
                </ul>
                <a href="#" data-transition class="mt-auto border border-white/20 py-4 bebas text-xl md:text-2xl hover:bg-white hover:text-black transition-all text-center block w-full">ASSINAR</a>
            </div>
            <!-- Card 2 (Featured) -->
            <div class="anim-pricing-card border-2 border-primary p-8 md:p-10 flex flex-col bg-primary/5 relative scale-100 md:scale-105 z-10">
                <div class="absolute top-0 right-0 bg-primary text-black bebas px-4 py-1 text-sm">RECOMENDADO</div>
                <span class="dm-mono text-primary text-xs mb-4 uppercase tracking-widest">MOST_POPULAR</span>
                <h3 class="bebas text-3xl md:text-4xl mb-2">PROFISSIONAL</h3>
                <div class="bebas text-5xl md:text-6xl text-primary mb-8">R$597<span class="text-xl">/mês</span></div>
                <ul class="dm-mono text-sm space-y-4 mb-12 uppercase">
                    <li>/ 200 LEADS POR MÊS</li>
                    <li>/ SUPORTE PRIORITÁRIO</li>
                    <li>/ CRM INTEGRADO</li>
                    <li>/ ANÁLISE DE SEO INCLUÍDA</li>
                </ul>
                <a href="#" data-transition class="mt-auto bg-primary text-black py-4 bebas text-xl md:text-2xl hover:bg-white transition-all text-center block w-full">ASSINAR AGORA</a>
            </div>
            <!-- Card 3 -->
            <div class="anim-pricing-card border border-white/10 p-8 md:p-10 flex flex-col hover:bg-white/5 transition-all">
                <span class="dm-mono text-secondary text-xs mb-4 uppercase tracking-widest">SCALE_UP</span>
                <h3 class="bebas text-3xl md:text-4xl mb-2">AGÊNCIA</h3>
                <div class="bebas text-5xl md:text-6xl text-primary mb-8">R$997<span class="text-xl">/mês</span></div>
                <ul class="dm-mono text-sm space-y-4 mb-12 text-secondary uppercase">
                    <li>/ LEADS ILIMITADOS</li>
                    <li>/ GERENTE DE CONTA</li>
                    <li>/ API ACCESS</li>
                    <li>/ WHITE LABEL REPORTS</li>
                </ul>
                <a href="#" data-transition class="mt-auto border border-white/20 py-4 bebas text-xl md:text-2xl hover:bg-white hover:text-black transition-all text-center block w-full">ASSINAR</a>
            </div>
        </div>
    </div>
</section>

<script>
    const REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!REDUCED_MOTION) {
        const cards = document.querySelectorAll('.anim-pricing-card');
        
        cards.forEach((card) => {
            const el = card as HTMLElement;
            
            el.addEventListener('mousemove', (e) => {
                const rect = el.getBoundingClientRect();
                const cardCenterX = rect.left + rect.width / 2;
                const cardCenterY = rect.top + rect.height / 2;
                
                const displacementX = ((e.clientX - cardCenterX) / rect.width) * 8;
                const displacementY = ((e.clientY - cardCenterY) / rect.height) * 8;
                
                el.style.transform = `translate(${displacementX}px, ${displacementY}px)`;
            });
            
            el.addEventListener('mouseleave', () => {
                el.style.transform = `translate(0, 0)`;
            });
            
            if (el.classList.contains('border-primary')) {
                el.addEventListener('mouseenter', () => {
                    el.classList.remove('anim-border-pulse');
                    void el.offsetWidth;
                    el.classList.add('anim-border-pulse');
                });
            }
        });
    }
</script>
