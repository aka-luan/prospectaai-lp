---
---
<section class="py-32 px-6">
    <div class="max-w-[1440px] mx-auto">
        <h2 class="bebas text-6xl mb-16">ESCOLHA SEU TERMINAL</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
            <!-- Card 1 -->
            <div class="border border-white/10 p-10 flex flex-col hover:bg-white/5 transition-all">
                <span class="dm-mono text-secondary text-xs mb-4 uppercase tracking-widest">ENTRY_LEVEL</span>
                <h3 class="bebas text-4xl mb-2">STARTER</h3>
                <div class="bebas text-6xl text-primary mb-8">R$297<span class="text-xl">/mês</span></div>
                <ul class="dm-mono text-sm space-y-4 mb-12 text-secondary uppercase">
                    <li>/ 50 LEADS POR MÊS</li>
                    <li>/ SUPORTE VIA EMAIL</li>
                    <li>/ DASHBOARD BÁSICO</li>
                    <li>/ FILTROS GEOGRÁFICOS</li>
                </ul>
                <button class="mt-auto border border-white/20 py-4 bebas text-2xl hover:bg-white hover:text-black transition-all">ASSINAR</button>
            </div>
            <!-- Card 2 (Featured) -->
            <div class="border-2 border-primary p-10 flex flex-col bg-primary/5 relative scale-105 z-10">
                <div class="absolute top-0 right-0 bg-primary text-black bebas px-4 py-1 text-sm">RECOMENDADO</div>
                <span class="dm-mono text-primary text-xs mb-4 uppercase tracking-widest">MOST_POPULAR</span>
                <h3 class="bebas text-4xl mb-2">PROFISSIONAL</h3>
                <div class="bebas text-6xl text-primary mb-8">R$597<span class="text-xl">/mês</span></div>
                <ul class="dm-mono text-sm space-y-4 mb-12 uppercase">
                    <li>/ 200 LEADS POR MÊS</li>
                    <li>/ SUPORTE PRIORITÁRIO</li>
                    <li>/ CRM INTEGRADO</li>
                    <li>/ ANÁLISE DE SEO INCLUÍDA</li>
                </ul>
                <button class="mt-auto bg-primary text-black py-4 bebas text-2xl hover:bg-white transition-all">ASSINAR AGORA</button>
            </div>
            <!-- Card 3 -->
            <div class="border border-white/10 p-10 flex flex-col hover:bg-white/5 transition-all">
                <span class="dm-mono text-secondary text-xs mb-4 uppercase tracking-widest">SCALE_UP</span>
                <h3 class="bebas text-4xl mb-2">AGÊNCIA</h3>
                <div class="bebas text-6xl text-primary mb-8">R$997<span class="text-xl">/mês</span></div>
                <ul class="dm-mono text-sm space-y-4 mb-12 text-secondary uppercase">
                    <li>/ LEADS ILIMITADOS</li>
                    <li>/ GERENTE DE CONTA</li>
                    <li>/ API ACCESS</li>
                    <li>/ WHITE LABEL REPORTS</li>
                </ul>
                <button class="mt-auto border border-white/20 py-4 bebas text-2xl hover:bg-white hover:text-black transition-all">ASSINAR</button>
            </div>
        </div>
    </div>
</section>
