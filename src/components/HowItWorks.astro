<section class="grid grid-cols-1 md:grid-cols-3 min-h-[600px] border-b border-white/10">
    <div class="relative p-12 border-b md:border-b-0 md:border-r border-white/10 flex flex-col justify-between group hover:bg-surface-container-high transition-colors">
        <span class="bebas text-[15vw] absolute top-0 right-4 opacity-[0.04] leading-none pointer-events-none">01</span>
        <div class="mt-auto">
            <h3 class="bebas text-4xl mb-4 text-primary">NICHO + CIDADE</h3>
            <p class="dm-mono text-secondary uppercase text-sm leading-relaxed">
                DEFINA QUEM VOCÊ QUER ATENDER. "RESTAURANTES EM SÃO PAULO" OU "OFICINAS EM CURITIBA". VOCÊ NO COMANDO.
            </p>
        </div>
    </div>
    <div class="relative p-12 border-b md:border-b-0 md:border-r border-white/10 flex flex-col justify-between group hover:bg-surface-container-high transition-colors">
        <span class="bebas text-[15vw] absolute top-0 right-4 opacity-[0.04] leading-none pointer-events-none">02</span>
        <div class="mt-auto">
            <h3 class="bebas text-4xl mb-4 text-primary">A GENTE PROSPECTA</h3>
            <p class="dm-mono text-secondary uppercase text-sm leading-relaxed">
                NOSSO ALGORITMO VARRE O GOOGLE MAPS EM TEMPO REAL. FILTRAMOS QUEM NÃO TEM SITE OU TEM SITE DESATUALIZADO.
            </p>
        </div>
    </div>
    <div class="relative p-12 flex flex-col justify-between group hover:bg-surface-container-high transition-colors">
        <span class="bebas text-[15vw] absolute top-0 right-4 opacity-[0.04] leading-none pointer-events-none">03</span>
        <div class="mt-auto">
            <h3 class="bebas text-4xl mb-4 text-primary">VOCÊ FECHA</h3>
            <p class="dm-mono text-secondary uppercase text-sm leading-relaxed">
                RECEBA A LISTA COM WHATSAPP, E-MAIL E NOME DO PROPRIETÁRIO. É SÓ ENVIAR A PROPOSTA E ASSINAR O CONTRATO.
            </p>
        </div>
    </div>
</section>
