<section class="relative min-h-screen flex flex-col justify-center items-center pt-24 px-6">
    <div class="w-full max-w-[1440px] flex flex-col items-start">
        <h1 class="bebas leading-[0.85] text-[12vw] md:text-[10vw] flex flex-col">
            <span class="text-on-surface">SEUS PRÓXIMOS</span>
            <span class="text-on-surface">CLIENTES ESTÃO</span>
            <span class="text-primary">NO GOOGLE.</span>
        </h1>
        <div class="mt-8 flex flex-col md:flex-row md:items-end justify-between w-full gap-8 md:gap-8 cursor-none">
            <div class="flex flex-col gap-4">
                <p class="dm-mono text-secondary max-w-md text-base md:text-lg leading-tight uppercase">
                    EXTRAÍMOS DADOS ESTRATÉGICOS DO GOOGLE MAPS PARA VOCÊ VENDER SITES PARA QUEM REALMENTE PRECISA.
                </p>
                <div class="hero-stat-lead dm-mono text-white text-lg md:text-xl uppercase flex items-center min-h-[1.2em]">1.247 PMEs prospectadas hoje</div>
            </div>
            <button class="bg-primary text-black px-8 py-5 md:px-12 md:py-6 bebas text-2xl md:text-3xl hover:bg-white transition-all duration-300 rounded-none flex items-center justify-center gap-4 group w-full md:w-auto cursor-none">
                COMEÇAR AGORA <span class="group-hover:translate-x-2 transition-transform">→</span>
            </button>
        </div>
    </div>
    <!-- Ticker -->
    <div class="absolute bottom-0 left-0 w-full bg-surface-container-low border-t border-white/10 py-4 ticker-wrap anim-ticker-wrap">
        <div class="ticker anim-ticker dm-mono text-primary text-sm tracking-[0.2em] uppercase">
            200 LEADS/MÊS ··· GOOGLE MAPS ··· BRASIL INTEIRO ··· AUTOMAÇÃO TOTAL ··· 200 LEADS/MÊS ··· GOOGLE MAPS ··· BRASIL INTEIRO ··· AUTOMAÇÃO TOTAL ··· 200 LEADS/MÊS ··· GOOGLE MAPS ··· BRASIL INTEIRO ··· AUTOMAÇÃO TOTAL ··· 
        </div>
    </div>
</section>

<script>
    import { createSlotMachineEffect } from '../utils/scramble';

    const REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!REDUCED_MOTION) {
        // 1. HERO GLITCH TEXT DECODE
        const charsPool = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&";
        const lines = document.querySelectorAll('h1.bebas span');
        
        lines.forEach((line, lineIndex) => {
            const originalText = line.textContent.trim();
            line.textContent = '';
            
            const chars = originalText.split('').map(char => {
                const span = document.createElement('span');
                span.className = 'char';
                span.textContent = char === ' ' ? ' ' : charsPool[Math.floor(Math.random() * charsPool.length)];
                span.dataset.target = char;
                line.appendChild(span);
                return span;
            });

            setTimeout(() => {
                chars.forEach((span, charIndex) => {
                    if (span.dataset.target === ' ') {
                        span.textContent = ' ';
                        return;
                    }
                    
                    const settleTime = charIndex * 40;
                    const startTime = performance.now();
                    
                    function animate(currentTime) {
                        const elapsed = currentTime - startTime;
                        
                        if (elapsed < settleTime) {
                            if (Math.floor(elapsed) % 3 === 0) {
                                span.textContent = charsPool[Math.floor(Math.random() * charsPool.length)];
                            }
                            requestAnimationFrame(animate);
                        } else {
                            span.textContent = span.dataset.target;
                        }
                    }
                    requestAnimationFrame(animate);
                });
            }, lineIndex * 200);
        });

        // 2. SLOT MACHINE COUNTER
        const statEl = document.querySelector('.hero-stat-lead');
        if (statEl) {
            createSlotMachineEffect(statEl, 1400, 80);
        }

        // 3. INFINITE TICKER PAUSE/PLAY CLONE
        const tickerWrap = document.querySelector('.ticker-wrap');
        const ticker = document.querySelector('.ticker');
        if (tickerWrap && ticker) {
            const clone = ticker.cloneNode(true);
            tickerWrap.appendChild(clone);
            
            tickerWrap.addEventListener('mouseenter', () => {
                ticker.style.animationPlayState = 'paused';
                clone.style.animationPlayState = 'paused';
            });
            tickerWrap.addEventListener('mouseleave', () => {
                ticker.style.animationPlayState = 'running';
                clone.style.animationPlayState = 'running';
            });
        }
    }
</script>
