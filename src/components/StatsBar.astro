<section class="bg-primary text-background py-10 px-6 stats-section">
    <div class="max-w-[1440px] mx-auto flex flex-col md:flex-row flex-wrap justify-center md:justify-between items-center gap-6 md:gap-8 bebas text-2xl sm:text-3xl md:text-4xl">
        <div class="flex items-center gap-4">
            <span class="anim-stat">+1.200 PMEs/MÊS</span>
        </div>
        <div class="hidden md:block w-px h-8 bg-background opacity-20"></div>
        <div class="flex items-center gap-4">
            <span class="anim-stat">TAXA DE RESPOSTA 5,4%</span>
        </div>
        <div class="hidden md:block w-px h-8 bg-background opacity-20"></div>
        <div class="flex items-center gap-4">
            <span class="anim-stat">TODO O BRASIL</span>
        </div>
    </div>
</section>

<script>
    import { createSlotMachineEffect } from '../utils/scramble';

    const REDUCED_MOTION = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!REDUCED_MOTION) {
        const statsSection = document.querySelector('section.stats-section');
        if (statsSection) {
            const observer = new IntersectionObserver((entries) => {
                if (entries[0].isIntersecting) {
                    const numbers = statsSection.querySelectorAll('.anim-stat');
                    numbers.forEach((num: HTMLElement, index) => {
                        createSlotMachineEffect(num, 800, 150, index * 150); 
                    });
                    observer.unobserve(statsSection);
                }
            }, { threshold: 0.5 });
            observer.observe(statsSection);
        }
    }
</script>
